# Normalize line endings to avoid LF/CRLF warnings across different OS platforms
* text=auto

# Explicitly declare text files to be normalized to LF inside the git repository
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
