# Frontend Environment Variables Template
# Copy this file, rename it to .env or .env.local, and fill in your actual values.

# ── API Connection ───────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Replace with your actual Google Client ID if implementing Google Sign-In
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your_google_client_id_here"
